    "aggressive": {
      "description": "积极模式：高频轮询 + 尾盘扫描 + 日切",
      "execute_orders": true,
      "schedule": {
        "interval_minutes": 5,
        "tail_attack_time": "14:40",
        "day_roll_time": "15:05"
      }
    }
  }
