# =============================================
# 鏉ヨ储 (Attract-wealth) 鐜鍙橀噺绀轰緥
# 澶嶅埗涓?.env 鍚庢寜瀹為檯鐜濉啓
# =============================================

# --- LLM 閰嶇疆 (OpenAI 鍏煎) ---
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat
LLM_DEEP_MODEL=deepseek-reasoner
LLM_QUICK_MODEL=deepseek-chat
LLM_PRICE_INPUT_PER_1M=0
LLM_PRICE_OUTPUT_PER_1M=0
LLM_MAX_LATENCY_MS=0
LLM_MAX_COST_PER_CALL_USD=0
LLM_DAILY_BUDGET_USD=0
LLM_GOVERN_DEGRADE_ENABLED=true
LLM_REQUEST_TIMEOUT_S=120
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF_MS=200

# --- 鏁版嵁婧?---
TUSHARE_TOKEN=

# --- 浜ゆ槗閫氶亾 ---
# 鍙€? simulation | ths_ipc | ths_auto | qmt
TRADING_CHANNEL=simulation

# --- THS UI 鑷姩鍖栵紙ths_auto锛?--
THS_EXE_PATH=C:\path\to\xiadan.exe
THS_EASYTRADER_BROKER=ths
THS_EASYTRADER_PYTHON32=
THS_EASYTRADER_RUNTIME_GUARD=true
THS_EASYTRADER_REQUIRE_32BIT=true
THS_EASYTRADER_REQUIRE_PROCESS_ACCESS=true
THS_AUTO_ALLOW_STUB=false
THS_AUTO_CLOSE_ON_DISCONNECT=false
THS_ACCOUNT=
THS_PASSWORD=

# --- miniQMT锛坬mt锛?--
QMT_PATH=C:\鍥介噾璇佸埜QMT\bin
QMT_ACCOUNT_ID=
# 鍏煎鏃у瓧娈碉紙浜岄€変竴锛?QMT_ACCOUNT=

# --- THS IPC锛坱hs_ipc锛?--
THS_IPC_HOST=127.0.0.1
THS_IPC_PORT=8089
THS_IPC_REQUIRE_RUNTIME=true
THS_IPC_ALLOW_MOCK=false

# --- 鏈嶅姟鍚姩鏃惰嚜鍔ㄦ媺璧?THS bridge ---
STARTUP_AUTO_START_THS_BRIDGE=false
THS_BRIDGE_SCRIPT=D:\同花顺软件\同花顺\script\laicai_bridge.py
THS_BRIDGE_PYTHON=
THS_BRIDGE_START_COMMAND=
THS_BRIDGE_START_TIMEOUT_S=12
THS_BRIDGE_STDOUT=data/smoke/reports/ths_bridge_stdout.log
THS_BRIDGE_STDERR=data/smoke/reports/ths_bridge_stderr.log
STARTUP_KEEP_THS_BRIDGE=false

# --- Redis锛堝彲閫夛級---
REDIS_URL=

# --- 瀹夊叏 ---
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- API 鉴权（生产环境必须设置）---
# 设置 API_KEY 后，前端与 SSE 请求必须携带此凭证。
# 不设置时鉴权关闭（仅适合本机开发）。
API_KEY=
API_AUTH_ENABLED=false

# --- 鏈嶅姟 ---
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=false
STARTUP_STRICT_PREFLIGHT=false
STARTUP_PREFLIGHT_INCLUDE_STABILITY=false

# --- 鑷姩宸¤埅 ---
AUTOPILOT_TEMPLATE=balanced
AUTO_EXECUTE_ORDERS=true
AUTO_POLLING_MINUTES=0
TAIL_ATTACK_TIME=
DAY_ROLL_TIME=15:05

# --- 瀵硅处闃绘柇鎭㈠ ---
RECON_AUTO_UNBLOCK_ENABLED=true
RECON_AUTO_UNBLOCK_OK_STREAK=2
RECON_UNLOCK_TOKEN=

# --- Dataflow 绋冲畾鎬э紙P2-B3锛?--
DATAFLOW_RUNTIME_PROFILE=ths_paper_default
DATA_PROVIDER_RATE_LIMIT_PER_MINUTE=120
DATA_PROVIDER_MIN_INTERVAL_MS=120
DATA_PROVIDER_MAX_WAIT_MS=400
DATA_PROVIDER_BACKOFF_RETRIES=2
DATA_PROVIDER_BACKOFF_BASE_MS=80
DATA_PROVIDER_BACKOFF_FACTOR=2.0
DATA_PROVIDER_BACKOFF_MAX_MS=1000

# --- 鏁版嵁璐ㄩ噺鍛婅闃堝€硷紙P2-B2/B3锛?--
DATA_QUALITY_RETRY_WARN=0.2
DATA_QUALITY_RETRY_BLOCK=0.6
DATA_QUALITY_RATE_LIMIT_WARN=0.2
DATA_QUALITY_RATE_LIMIT_BLOCK=0.5

# --- P3 澶辫触闄嶇骇绛栫暐鐭╅樀 ---
TRADE_DEGRADE_POLICY_ENABLED=true
TRADE_DEGRADE_POLICY_VERSION=2026.04.08.1
TRADE_DEGRADE_MIN_MATCHES=1
TRADE_DEGRADE_CONFLICT_STRATEGY=highest_priority
TRADE_DEGRADE_RULE_PRIORITIES=
TRADE_DEGRADE_ANALYST_LLM_FAIL_COUNT=2
TRADE_DEGRADE_DATAFLOW_ALERT_LEVELS=critical
TRADE_DEGRADE_LLM_LATENCY_ACTION=warn_only
TRADE_DEGRADE_LLM_COST_ACTION=warn_only
TRADE_DEGRADE_LLM_BUDGET_ACTION=force_hold
TRADE_DEGRADE_ENABLED_RULES=
TRADE_DEGRADE_DISABLED_RULES=
TRADE_BUDGET_RECOVERY_ENABLED=true
TRADE_BUDGET_RECOVERY_RATIO=0.8
TRADE_BUDGET_RECOVERY_COOLDOWN_S=300
TRADE_BUDGET_RECOVERY_ACTION=force_hold

# --- Live smoke锛圥1-H2锛?--
# --- P4 缁涙牜鏆愰悧鍫熸拱闂傘劎顩?---
STRATEGY_GATE_MIN_TRADES=20
STRATEGY_GATE_MIN_WIN_RATE=0.52
STRATEGY_GATE_MAX_DRAWDOWN=0.2
STRATEGY_GATE_MIN_NET_PNL=0
STRATEGY_GATE_MIN_SHARPE=0.5
STRATEGY_GATE_DEFAULT_MARKET=CN
STRATEGY_GATE_DEFAULT_TEMPLATE=default
# 绀轰緥锛?# STRATEGY_GATE_RULES_JSON={"markets":{"CN":{"min_win_rate":0.55}},"templates":{"momentum":{"min_sharpe":0.8}},"market_template":{"CN":{"momentum":{"min_trades":30}}}}
STRATEGY_GATE_RULES_JSON=

SMOKE_DEFAULT_CHANNELS=ths_ipc,simulation
SEALOFF_DEFAULT_PROFILE=ths_sim_strict
SMOKE_ALLOW_LIVE_ORDER=false
SMOKE_TICKER=000001
SMOKE_PRICE=10
SMOKE_QUANTITY=100
SMOKE_SIDE=BUY

