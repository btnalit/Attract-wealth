TRADE_BUDGET_RECOVERY_RATIO=0.8
TRADE_BUDGET_RECOVERY_COOLDOWN_S=300
TRADE_BUDGET_RECOVERY_ACTION=force_hold

# --- Live smokeй”ӣеңҘ1-H2й”ӣ?--
# --- P4 зјҒж¶ҷзүңйҸҶж„°жӮ§йҚ«зҶёжӢұй—ӮеӮҳеҠҺйЎ©?---
STRATEGY_GATE_MIN_TRADES=20
