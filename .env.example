TRADE_DEGRADE_LLM_LATENCY_ACTION=warn_only
TRADE_DEGRADE_LLM_COST_ACTION=warn_only
TRADE_DEGRADE_LLM_BUDGET_ACTION=force_hold
TRADE_DEGRADE_ENABLED_RULES=
TRADE_DEGRADE_DISABLED_RULES=
