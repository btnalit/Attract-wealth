# =============================================
# 来财 (Attract-wealth) 环境变量配置
# 复制为 .env 并填入你的密钥
# =============================================

# --- LLM 配置 (OpenAI 兼容协议) ---
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat
# 深度思考模型 (用于复杂分析)
LLM_DEEP_MODEL=deepseek-reasoner
# 快速模型 (用于简单任务)
LLM_QUICK_MODEL=deepseek-chat

# --- A 股数据源 ---
# Tushare (https://tushare.pro)
TUSHARE_TOKEN=
# AkShare 免费无需 token
# BaoStock 免费无需 token

# --- 交易执行通道 ---
# 可选: simulation | ths_auto | qmt
TRADING_CHANNEL=simulation

# --- 同花顺 UI 自动化 (通道 B) ---
THS_EXE_PATH=C:\同花顺\xiadan.exe
THS_ACCOUNT=
THS_PASSWORD=

# --- miniQMT (通道 A) ---
QMT_PATH=C:\国金证券QMT\bin
QMT_ACCOUNT=

# --- Redis (可选) ---
REDIS_URL=

# --- 安全 ---
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- 服务 ---
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
