п»ҝ# =============================================
# йҸүгғЁеӮЁ (Attract-wealth) йҗңоҲҡо•ЁйҚҷж©Җеҷәз»ҖиҪ°з·Ҙ
# жҫ¶е¶…еҹ—ж¶“?.env йҚҡеәўеҜңзҖ№зӮәжӘҜйҗңоҲҡо•ЁжҝүоӮўе•“
# =============================================

# --- LLM й–°е¶Үз–Ҷ (OpenAI йҚҸз…ҺоҶҗ) ---
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat
LLM_DEEP_MODEL=deepseek-reasoner
LLM_QUICK_MODEL=deepseek-chat
LLM_PRICE_INPUT_PER_1M=0
LLM_PRICE_OUTPUT_PER_1M=0
LLM_MAX_LATENCY_MS=0
LLM_MAX_COST_PER_CALL_USD=0
LLM_DAILY_BUDGET_USD=0
LLM_GOVERN_DEGRADE_ENABLED=true
LLM_REQUEST_TIMEOUT_S=120
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF_MS=200

# --- йҸҒзүҲеөҒе©§?---
TUSHARE_TOKEN=

# --- жөңгӮҶж§—й–«ж°¶дәҫ ---
# йҚҷоҲһвӮ¬? simulation | ths_ipc | ths_auto | qmt
TRADING_CHANNEL=simulation

# --- THS UI й‘·оҒ„е§©йҚ–ж өзҙҷths_autoй”ӣ?--
THS_EXE_PATH=C:\path\to\xiadan.exe
THS_EASYTRADER_BROKER=ths
THS_EASYTRADER_PYTHON32=
THS_EASYTRADER_RUNTIME_GUARD=true
THS_EASYTRADER_REQUIRE_32BIT=true
THS_EASYTRADER_REQUIRE_PROCESS_ACCESS=true
THS_AUTO_ALLOW_STUB=false
THS_AUTO_CLOSE_ON_DISCONNECT=false
THS_ACCOUNT=
THS_PASSWORD=

# --- miniQMTй”ӣеқ¬mtй”ӣ?--
QMT_PATH=C:\йҚҘд»Ӣеҷҫз’ҮдҪёеҹңQMT\bin
QMT_ACCOUNT_ID=
# йҚҸз…ҺоҶҗйҸғСғз“§еЁҲзўүзҙҷжөңеІ„вӮ¬еӨүз«ҙй”ӣ?QMT_ACCOUNT=

# --- THS IPCй”ӣеқұhs_ipcй”ӣ?--
THS_IPC_HOST=127.0.0.1
THS_IPC_PORT=8089
THS_IPC_REQUIRE_RUNTIME=true
THS_IPC_ALLOW_MOCK=false

# --- йҸҲе¶…е§ҹйҚҡоҲҡе§©йҸғжғ°еҡңйҚ”г„ҰеӘәз’§?THS bridge ---
STARTUP_AUTO_START_THS_BRIDGE=false
